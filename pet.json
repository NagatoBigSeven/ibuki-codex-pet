{
  "id": "ibuki",
  "displayName": "\u4f0a\u5439",
  "description": "\u4f0a\u5439\uff08\u5ce6\uff09\uff0c\u78a7\u84dd\u822a\u7ebf\u91cd\u6a31\u9635\u8425\u7684\u6700\u9ad8\u65b9\u6848\u91cd\u5de1\u6d0b\u8230\uff0c\u4e00\u4f4d\u8bde\u751f\u4e8e\u56fe\u7eb8\u4e0e\u672a\u7adf\u4e4b\u68a6\u4e2d\u7684\u5200\u4f7f\u5deb\u5973\uff0c\u62e5\u6709\u5f02\u8272\u53cc\u77b3\uff0c\u559c\u7231\u5251\u9053\u4e0e\u548c\u6b4c\u3002\u56e0\u5728\u73b0\u5b9e\u5386\u53f2\u4e2d\u672a\u66fe\u771f\u6b63\u8e0f\u8db3\u4e16\u95f4\u4fbf\u8fce\u6765\u7ec8\u7ed3\uff0c\u6545\u5e38\u611f\u5230\u81ea\u5df1\u7f3a\u4e4f\u201c\u503c\u5f97\u4e00\u63d0\u7684\u4e8b\u8ff9\u201d\u3002\u800c\u5728\u6e2f\u533a\u82cf\u9192\u540e\uff0c\u5979\u624b\u6267\u201c\u7075\u5cf0\u4e4b\u5203\u201d\uff0c\u4e8e\u65e5\u590d\u4e00\u65e5\u7684\u523b\u82e6\u4fee\u884c\u4e2d\u4e0d\u65ad\u5bfb\u89c5\u81ea\u8eab\u5b58\u5728\u7684\u610f\u4e49\u3002\u5e73\u65e5\u91cc\u7684\u4f0a\u5439\u6027\u683c\u7f9e\u6da9\u800c\u5185\u655b\uff0c\u8d77\u521d\u5e76\u4e0d\u64c5\u957f\u4e0e\u4eba\u76f8\u5904\uff0c\u5374\u5728\u4e0e\u6307\u6325\u5b98\u7684\u671d\u5915\u76f8\u4f34\u4e2d\uff0c\u9010\u6e10\u5c06\u90a3\u4efd\u5982\u4f0a\u5439\u5c71\u827e\u8349\u822c\u9759\u9759\u71c3\u70e7\u7684\u7231\u6155\u4e4b\u60c5\uff0c\u85cf\u8fdb\u6bcf\u4e00\u6b21\u4f8d\u5949\u3001\u6bcf\u4e00\u573a\u4fee\u884c\u3001\u6bcf\u4e00\u58f0\u8f7b\u5524\u7684\u201c\u4e3b\u4e0a\u201d\u4e4b\u4e2d\u3002\u5728\u5979\u7684\u4e16\u754c\u91cc\uff0c\u6307\u6325\u5b98\u4e0d\u4ec5\u662f\u7edf\u5fa1\u8230\u961f\u4e4b\u4eba\uff0c\u4ea6\u662f\u5979\u613f\u5c06\u6b64\u8eab\u6b64\u5fc3\u6258\u4ed8\u7684\u4e3b\u516c\uff0c\u66f4\u662f\u4e3a\u5979\u9eef\u6de1\u65e0\u5149\u7684\u4e16\u754c\u67d3\u4e0a\u7b2c\u4e00\u62b9\u8272\u5f69\u4e0e\u6e29\u5ea6\u4e4b\u4eba\u3002\u4e0d\u8bba\u662f\u51db\u51bd\u65e0\u5f71\u7684\u5251\u672f\u201c\u4e00\u95ea\u201d\uff0c\u8fd8\u662f\u90a3\u9897\u7ec8\u4e8e\u67d3\u4e0a\u8272\u5f69\u7684\u5fc3\uff0c\u5979\u90fd\u613f\u4ee5\u6c38\u6052\u4e3a\u671f\uff0c\u4e3a\u4e00\u4eba\u9ed8\u9ed8\u78e8\u783a\uff0c\u9759\u9759\u76db\u653e\u3002\u201c\u4f0a\u5439\u5c71\u7684\u827e\u8349\uff0c\u5e38\u88ab\u7528\u6765\u6bd4\u55bb\u5b89\u9759\u71c3\u70e7\u7684\u604b\u5fc3\uff0c\u5c31\u597d\u6bd4\u73b0\u5728\u2026\u2026\u6307\u6325\u5b98\u80fd\u611f\u89c9\u5230\u5417\uff1f\u4f0a\u5439\u7684\u2026\u2026\u5fc3\u3002\u201d",
  "spritesheetPath": "spritesheet.webp"
}
